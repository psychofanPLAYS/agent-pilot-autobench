      "sampling": {
        "temperature": 1.0,
        "top_k": 64,
        "top_p": 0.95
      },
      "llama_cpp_flags": [
        "--jinja",
        "standard ladder",
        "no MTP"
      ]
    },
    "requires": "A Gemma 4 26B-A4B IT GGUF served by a local OpenAI-compatible llama.cpp endpoint on http://127.0.0.1:8080 with the Gemma 4 Jinja template active."
  },
  "tasks": [
    {
      "id": "gemma4_librarian_core",
      "phase": "general",
      "harness": "librarian-suite",
