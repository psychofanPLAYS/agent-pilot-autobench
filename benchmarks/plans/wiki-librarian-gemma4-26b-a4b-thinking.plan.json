        [
          "uv",
          "run",
          "--extra",
          "dev",
          "python",
          "-m",
          "gguf_limit_bench.librarian_suite",
          "--model",
          "{model}",
          "--base-url",
          "http://127.0.0.1:8080",
          "--out-dir",
          "{task_dir}",
          "--score-out",
          "{task_dir}/score.json",
          "--settings-json",
          "{\"plan_kind\":\"wiki_librarian_gemma4_26b_a4b_thinking\",\"thinking\":\"on\",\"template\":\"gemma4_jinja\",\"temperature\":1.0,\"top_k\":64,\"top_p\":0.95,\"source_doc\":\"docs/feature-requests/wiki-librarian-bench/12-model-plan-gemma4.md\"}",
